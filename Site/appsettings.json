{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft": "Warning",
			"Microsoft.Hosting.Lifetime": "Information"
		}
	},
	"AllowedHosts": "*",
	"Serilog": {
		"Using": [
			"Serilog.Sinks.File",
			"Serilog.Sinks.NewRelic.Logs",
			"NewRelic.LogEnrichers.Serilog"
		],
		"MinimumLevel": {
			"Default": "Warning"
		},
		"Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithNewRelicLogsInContext" ],
		"WriteTo": []
	},
	"SimulatorClient": {
		"GarageBaseUrl": null,
		"GarageEndpoint": "/garage",
		"GarageConfigCacheMinutes": 5,
		"SyncGarageOnStartup": false,
		"FailStartupIfGarageSyncFails": false,
		"UseMockGarageOnFailure": true
	},
	"WebhookSignature": {
		"Enabled": false,
		"HeaderName": "Webhook-Signature",
		"Secret": null,
		"ToleranceSeconds": 300
	}
}
